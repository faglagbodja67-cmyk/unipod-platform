NODE_ENV=production
HOST=0.0.0.0
PORT=3000
DATA_DIR=/app/data

# Separate multiple origins with commas if your front-end is served elsewhere.
ALLOWED_ORIGINS=https://votre-domaine.com,https://www.votre-domaine.com

# Force the auth cookie to use Secure. Enabled automatically when NODE_ENV=production.
FORCE_SECURE_COOKIE=true

# Required for the first admin account in a fresh deployment.
ADMIN_NAME=Administrateur Principal
ADMIN_EMAIL=admin@votre-domaine.com
ADMIN_PASSWORD=changez-ce-mot-de-passe

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre-email@gmail.com
SMTP_PASS=votre-mot-de-passe-app
SMTP_FROM=UNIPOD <votre-email@gmail.com>
